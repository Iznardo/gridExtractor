# Credenciales — NO versionar este archivo cuando se rellene.
# Copiar a `.env` y completar.

# API key de GRID.gg (la usa grid-minion).
GRID_API_KEY=
RIOT_API_KEY=

# PostgreSQL. docker-compose.yml lee estas mismas variables para arrancar el
# contenedor, y src/db/conn.py las usa para conectarse desde Python.
# PGPORT es el puerto publicado al host (cambialo si 5432 ya esta ocupado); el
# contenedor de la API conecta a la BD por la red interna en 5432, no por este.
PGHOST=localhost
PGPORT=5432
PGUSER=loldata
PGPASSWORD=
PGDATABASE=loldata

# Puerto en el que el contenedor de la API (servicio `api`) se publica al host.
API_PORT=8000
