# Credenciales — NO versionar este archivo cuando se rellene.
# Copiar a `.env` y completar.

# API key de GRID.gg (la usa grid-minion).
GRID_API_KEY=

# PostgreSQL. docker-compose.yml lee estas mismas variables para arrancar el
# contenedor, y src/db/conn.py las usa para conectarse desde Python.
PGHOST=localhost
PGPORT=5432
PGUSER=loldata
PGPASSWORD=
PGDATABASE=loldata
