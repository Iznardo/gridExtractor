# Credentials — do NOT commit this file once filled in.
# Copy to `.env` and complete.

# GRID.gg API key (used by grid-minion).
GRID_API_KEY=
RIOT_API_KEY=

# PostgreSQL. docker-compose.yml reads these same variables to start the
# container, and src/db/conn.py uses them to connect from Python.
# PGPORT is the port published to the host (change it if 5432 is already in use);
# the API container connects to the DB over the internal network on 5432, not this.
PGHOST=localhost
PGPORT=5432
PGUSER=loldata
PGPASSWORD=
PGDATABASE=loldata

# Port on which the API container (service `api`) is published to the host.
# Published on 127.0.0.1 only (loopback): the API is reached through the `web`
# nginx proxy, not directly from the network.
API_PORT=8000

# Port on which the frontend (service `web`, nginx) is published to the host.
# The browser hits this; nginx serves the static bundle and proxies /api to the
# API over the internal compose network.
WEB_PORT=8080

# Bind address for the frontend port. Default 0.0.0.0 = every interface (LAN +
# Tailscale). Set to 127.0.0.1 to expose the front ONLY through `tailscale serve`
# (see DEPLOY.md), keeping it off the LAN and public interfaces.
WEB_HOST=0.0.0.0
